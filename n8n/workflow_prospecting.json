        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json) }}",
        "options": {
          "retry": {"numberOfRetries": 3, "waitBetweenRetries": 5000},
          "response": {"response": {"neverError": true, "responseFormat": "json"}}
        }
      },
      "id": "crm-ingest",
      "name": "POST /api/automation/ingest",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2840, 290]
