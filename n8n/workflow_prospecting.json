          "conditions": [
            {
              "id": "ok-and-personal",
              "leftValue": "={{ $json.shouldAutoSendEmail }}",
              "rightValue": true,
              "operator": {"type": "boolean", "operation": "equals"}
            },
            {
              "id": "ingest-ok",
              "leftValue": "={{ $json.companyId || $json.id }}",
              "rightValue": "",
              "operator": {"type": "string", "operation": "notEmpty"}
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "if-personal-email",
      "name": "Si es email personal",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [3100, 290]
