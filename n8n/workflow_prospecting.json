    {
      "parameters": {
        "method": "POST",
        "url": "=https://api.apollo.io/v1/mixed_people/search",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {"name": "Content-Type", "value": "application/json"},
            {"name": "X-Api-Key", "value": "={{$env.APOLLO_API_KEY}}"}
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"organization_ids\": [\"{{$json.companyPayload.id}}\"],\n  \"person_titles\": [\"CEO\", \"Chief Executive Officer\", \"CTO\", \"Chief Technology Officer\", \"Talent Manager\", \"Head of Talent\", \"HR Director\"],\n  \"page\": 1,\n  \"per_page\": 5\n}",
        "options": {
          "retry": {"numberOfRetries": 3, "waitBetweenRetries": 5000}
        }
      },
      "id": "apollo-contacts",
      "name": "Apollo.io - Buscar contactos",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2320, 290]
    },
    {
      "parameters": {
        "jsCode": "// Construir payload final para enviar al CRM\n// Prioriza: CEO > CTO > Talent Manager > HR\n// Marca email como 'personal' (ej: juan.perez@empresa.com) vs 'generic' (info@, contact@)\n\nconst results = [];\n\nfor (const item of $input.all()) {\n  const company = item.json.companyPayload;\n  const people = item.json.people || [];\n\n  // Ordenar contactos por prioridad\n  const rolePriority = { 'CEO': 1, 'Chief Executive Officer': 1, 'CTO': 2, 'Chief Technology Officer': 2, 'Talent Manager': 3, 'Head of Talent': 3, 'HR Director': 4 };\n  const sorted = people\n    .filter(p => p.email)\n    .sort((a,b) => (rolePriority[a.title] || 99) - (rolePriority[b.title] || 99));\n\n  const primary = sorted[0];\n  if (!primary) continue; // no hay contacto con email, descartar\n\n  // Detectar si es email genérico o personal\n  const email = primary.email.toLowerCase();\n  const isGeneric = /^(info|contact|contacto|admin|sales|ventas|support|soporte|hello|hi)@/.test(email);\n\n  // Normalizar rol al enum del backend (CEO|CTO|TALENT_MANAGER|HR)\n  const title = (primary.title || '').toLowerCase();\n  let role = 'CEO';\n  if (title.includes('cto') || title.includes('technology')) role = 'CTO';\n  else if (title.includes('talent')) role = 'TALENT_MANAGER';\n  else if (title.includes('hr') || title.includes('human')) role = 'HR';\n\n  results.push({\n    json: {\n      // Empresa\n      name: company.name,\n      industry: company.industry || 'Otro',\n      size: (company.estimated_num_employees || '').toString(),\n      country: 'Colombia',\n      department: item.json.department,\n      website: company.website_url || null,\n      linkedinUrl: company.linkedin_url,\n      assignedTo: item.json.assignedTo,\n      // Contacto primario\n      contact: {\n        name: `${primary.first_name || ''} ${primary.last_name || ''}`.trim(),\n        email: primary.email,\n        role: role,\n        isGeneric: isGeneric\n      },\n      // Metadata\n      source: 'apollo',\n      // Auto-email: solo si es personal\n      shouldAutoSendEmail: !isGeneric\n    }\n  });\n}\n\nreturn results;"
      },
      "id": "build-payload",
      "name": "Construir payload + clasificar email",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2580, 290]
    },
